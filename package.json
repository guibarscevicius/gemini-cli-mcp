{
  "name": "@guibarscevicius/gemini-cli-mcp",
  "version": "0.4.1",
  "description": "Safe MCP server wrapping the official Gemini CLI — stateful sessions, no shell injection, subscription auth",
  "type": "module",
  "bin": {
    "gemini-cli-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "keywords": [
    "gemini",
    "mcp",
    "claude",
    "llm",
    "model-context-protocol",
    "gemini-cli"
  ],
  "author": "Gui Barscevicius",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "glob": "^13.0.6",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guibarscevicius/gemini-cli-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/guibarscevicius/gemini-cli-mcp/issues"
  },
  "homepage": "https://github.com/guibarscevicius/gemini-cli-mcp#readme"
}
